generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── Workspace ─────────────────────────────────────────────────────────────────
model Workspace {
  id                  String   @id @default(cuid())
  name                String
  industry            String
  createdAt           DateTime @default(now())
  poApprovalThreshold Float    @default(0)
  currency            String   @default("USD") // Phase 15
  whatsappEnabled     Boolean  @default(false) // Phase 11
  whatsappStages      String   @default("Confirmed,Shipped,Delivered") // Phase 11
  quickbooksConnected Boolean  @default(false) // Phase 17
  xeroConnected       Boolean  @default(false) // Phase 17
  returnAddress       String   @default("")
  returnInstructions  String   @default("")

  users                   User[]
  orders                  Order[]
  invoices                Invoice[]
  customers               Customer[]
  quotes                  Quote[]
  inventory               InventoryItem[]
  suppliers               Supplier[]
  purchaseOrders          PurchaseOrder[]
  shipments               Shipment[]
  returns                 Return[]
  pricingRules            PricingRule[]
  contracts               Contract[]
  ediPartners             EdiPartner[]
  ediTransactions         EdiTransaction[]
  tickets                 Ticket[]
  notifications           Notification[]
  customerAccounts        CustomerAccount[]
  notificationPreferences NotificationPreference[]
  paymentRecords          PaymentRecord[]
}

// ── User ──────────────────────────────────────────────────────────────────────
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        String    @default("operator")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())

  notificationPreferences NotificationPreference[]
}

// ── Order ─────────────────────────────────────────────────────────────────────
model Order {
  id          String    @id @default(cuid())
  customer    String
  sku         String
  items       Int       @default(1)
  value       Float     @default(0)
  stage       String    @default("Placed")
  priority    String    @default("MED")
  source      String    @default("manual")
  notes       String    @default("")
  quoteId     String?
  quote       Quote?    @relation(fields: [quoteId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  shipments Shipment[]
  invoices  Invoice[]
  returns   Return[]
}

// ── Invoice ───────────────────────────────────────────────────────────────────
model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String
  customer      String
  items         Json
  subtotal      Float     @default(0)
  tax           Float     @default(0)
  total         Float     @default(0)
  amountPaid    Float     @default(0)
  paymentTerms  String    @default("Net 30")
  paymentMethod String    @default("")
  paymentDate   String    @default("")
  issueDate     String
  dueDate       String
  status        String    @default("unpaid")
  notes         String    @default("")
  currency      String    @default("USD")
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id])
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  payments PaymentRecord[]
}

// ── Customer ──────────────────────────────────────────────────────────────────
model Customer {
  id                   String    @id @default(cuid())
  name                 String
  contactName          String
  email                String
  phone                String    @default("")
  country              String    @default("")
  industry             String    @default("")
  creditLimit          Float     @default(0)
  balanceDue           Float     @default(0)
  totalSpend           Float     @default(0)
  status               String    @default("active")
  portalCode           String    @default("")
  notes                String    @default("")
  orders               Json      @default("[]")
  whatsappPaused       Boolean   @default(false)
  onCreditHold         Boolean   @default(false)
  creditHoldReason     String    @default("")
  daysSalesOutstanding Float     @default(0)
  avgPaymentDaysLate   Float     @default(0)
  returnRate           Float     @default(0)
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  createdAt            DateTime  @default(now())

  @@unique([portalCode, workspaceId])
}

// ── Quote ─────────────────────────────────────────────────────────────────────
model Quote {
  id           String    @id @default(cuid())
  quoteNumber  String
  customer     String
  items        Json
  subtotal     Float     @default(0)
  discountAmt  Float     @default(0)
  tax          Float     @default(0)
  total        Float     @default(0)
  validUntil   String
  paymentTerms String    @default("Net 30")
  notes        String    @default("")
  status       String    @default("draft")
  prompt       String    @default("")
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())

  orders Order[]
}

// ── Inventory Item ────────────────────────────────────────────────────────────
model InventoryItem {
  id           String    @id @default(cuid())
  sku          String
  name         String
  category     String
  stockLevel   Int       @default(0)
  reorderPoint Int       @default(0)
  reorderQty   Int       @default(0)
  unitCost     Float     @default(0)
  warehouse    String    @default("")
  zone         String    @default("A")
  binLocation  String    @default("")
  lastSynced   String
  supplier     String    @default("")
  supplierId   String?
  supplierRef  Supplier? @relation(fields: [supplierId], references: [id])
  lastPoDate   String    @default("")
  autoPoCount  Int       @default(0)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
}

// ── Supplier ──────────────────────────────────────────────────────────────────
model Supplier {
  id                    String    @id @default(cuid())
  name                  String
  contactName           String
  email                 String
  phone                 String    @default("")
  country               String    @default("")
  category              String    @default("other")
  status                String    @default("active")
  paymentTerms          String    @default("Net 30")
  leadTimeDays          Int       @default(14)
  rating                Int       @default(3)
  notes                 String    @default("")
  onTimeDeliveryPercent Float     @default(100)
  qualityScore          Float     @default(5)
  totalOrdersCount      Int       @default(0)
  lastPoDate            String    @default("")
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  createdAt             DateTime  @default(now())

  inventoryItems InventoryItem[]
}

// ── Purchase Order ────────────────────────────────────────────────────────────
model PurchaseOrder {
  id                  String    @id @default(cuid())
  poNumber            String
  supplierId          String
  supplierName        String
  items               Json
  subtotal            Float     @default(0)
  tax                 Float     @default(0)
  total               Float     @default(0)
  status              String    @default("draft")
  paymentTerms        String    @default("Net 30")
  expectedDate        String
  notes               String    @default("")
  rejectionNote       String    @default("")
  approvalStatus      String    @default("not_required")
  approvedBy          String    @default("")
  approvedAt          String    @default("")
  isAutoPo            Boolean   @default(false)
  triggeredByLowStock Boolean   @default(false)
  lowStockSkuId       String    @default("")
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  createdAt           DateTime  @default(now())
}

// ── Shipment ──────────────────────────────────────────────────────────────────
model Shipment {
  id             String    @id @default(cuid())
  shipmentNumber String
  orderId        String?
  order          Order?    @relation(fields: [orderId], references: [id])
  customer       String
  carrier        String    @default("Other")
  trackingNumber String    @default("")
  status         String    @default("pending")
  origin         String    @default("")
  destination    String    @default("")
  weight         String    @default("")
  dimensions     String    @default("")
  estimatedDate  String    @default("")
  deliveredDate  String    @default("")
  events         Json      @default("[]")
  notes          String    @default("")
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
}

// ── Pricing Rule ─────────────────────────────────────────────────────────────
model PricingRule {
  id           String    @id @default(cuid())
  name         String
  type         String
  minQty       Int       @default(0)
  customerName String    @default("")
  discountPct  Float     @default(0)
  active       Boolean   @default(true)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
}

// ── Contract & SLA Tracker ───────────────────────────────────────────────────
model Contract {
  id             String    @id @default(cuid())
  contractNumber String
  title          String
  customer       String
  minOrderQty    Int       @default(0)
  agreedPricing  String    @default("")
  deliverySLA    Int       @default(7)
  value          Float     @default(0)
  startDate      String
  expiryDate     String
  status         String    @default("active")
  notes          String    @default("")
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime  @default(now())
}

// ── Return / RMA ──────────────────────────────────────────────────────────────
model Return {
  id              String    @id @default(cuid())
  rmaNumber       String
  orderId         String?
  order           Order?    @relation(fields: [orderId], references: [id])
  customer        String
  sku             String
  qty             Int       @default(1)
  reason          String    @default("other")
  description     String    @default("")
  status          String    @default("requested")
  refundAmount    Float     @default(0)
  refundMethod    String    @default("original")
  refundProcessed Boolean   @default(false)
  refundDate      String    @default("")
  notes           String    @default("")
  customerEmail   String    @default("")
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ── EDI Trading Partner ───────────────────────────────────────────────────────
model EdiPartner {
  id            String           @id @default(cuid())
  name          String
  standard      String           @default("X12")
  isaQualifier  String           @default("01")
  isaId         String           @default("")
  partnerQual   String           @default("01")
  partnerId     String           @default("")
  unbSenderId   String           @default("")
  unbReceiverId String           @default("")
  txSets        String           @default("850,855,856,810")
  active        Boolean          @default(true)
  notes         String           @default("")
  workspaceId   String
  workspace     Workspace        @relation(fields: [workspaceId], references: [id])
  transactions  EdiTransaction[]
  createdAt     DateTime         @default(now())
}

// ── EDI Transaction Log ───────────────────────────────────────────────────────
model EdiTransaction {
  id            String     @id @default(cuid())
  direction     String
  standard      String     @default("X12")
  txSet         String
  controlNumber String     @default("")
  partnerId     String
  partner       EdiPartner @relation(fields: [partnerId], references: [id])
  status        String     @default("received")
  rawPayload    String     @db.Text
  parsedJson    Json?
  errorMsg      String     @default("")
  workspaceId   String
  workspace     Workspace  @relation(fields: [workspaceId], references: [id])
  createdAt     DateTime   @default(now())
}

// ── Ticket ────────────────────────────────────────────────────────────────────
model Ticket {
  id           String          @id @default(cuid())
  ticketNumber String
  title        String
  description  String          @default("")
  type         String          @default("issue")
  priority     String          @default("medium")
  status       String          @default("open")
  assignedTo   String          @default("")
  assignedName String          @default("")
  raisedBy     String          @default("")
  raisedName   String          @default("")
  linkedType   String          @default("")
  linkedId     String          @default("")
  linkedLabel  String          @default("")
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id])
  comments     TicketComment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String   @default("")
  authorName String   @default("")
  body       String
  createdAt  DateTime @default(now())
}

// ── Notification ──────────────────────────────────────────────────────────────
model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  type        String    @default("info")
  severity    String    @default("info")
  title       String
  body        String    @default("")
  tab         String    @default("")
  linkedType  String    @default("")
  linkedId    String    @default("")
  groupKey    String    @default("")
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, groupKey, createdAt])
}

// ── Notification Preference ───────────────────────────────────────────────────
// Per-user alert routing preferences. One row per user per workspace.
model NotificationPreference {
  id               String    @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertOrdersAbove Float     @default(0) // 0 = all orders
  sendEmail        Boolean   @default(false)
  sendSms          Boolean   @default(false)
  useDigest        Boolean   @default(false)
  digestTime       String    @default("09:00")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([workspaceId, userId])
}

// ── Payment Record ────────────────────────────────────────────────────────────
// One row per payment transaction against an invoice.
// type: payment | refund | credit | overpayment
model PaymentRecord {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  amount      Float     @default(0)
  type        String    @default("payment")
  method      String    @default("")
  reference   String    @default("")
  notes       String    @default("")
  createdAt   DateTime  @default(now())
}

// ── Customer Portal ───────────────────────────────────────────────────────────
model CustomerAccount {
  id          String            @id @default(cuid())
  email       String
  name        String            @default("")
  password    String            @default("")
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  sessions    CustomerSession[]
  createdAt   DateTime          @default(now())

  @@unique([email, workspaceId])
}

model CustomerSession {
  id        String          @id @default(cuid())
  token     String          @unique @default(cuid())
  accountId String
  account   CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime        @default(now())
}
