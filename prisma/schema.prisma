generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── Workspace ─────────────────────────────────────────────────────────────────
model Workspace {
  id                  String   @id @default(cuid())
  name                String
  industry            String
  createdAt           DateTime @default(now())
  poApprovalThreshold Float    @default(0)
  currency            String   @default("USD")   // Phase 15
  whatsappEnabled     Boolean  @default(false)   // Phase 11
  whatsappStages      String   @default("Confirmed,Shipped,Delivered") // Phase 11
  quickbooksConnected Boolean  @default(false)   // Phase 17
  xeroConnected       Boolean  @default(false)   // Phase 17
  returnAddress       String   @default("")      // Portal returns: ship-to address shown after approval
  returnInstructions  String   @default("")      // Portal returns: instructions shown after approval

  users          User[]
  orders         Order[]
  invoices       Invoice[]
  customers      Customer[]
  quotes         Quote[]
  inventory      InventoryItem[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  shipments      Shipment[]
  returns        Return[]
  pricingRules   PricingRule[]
  contracts      Contract[]       // Phase 12
  ediPartners    EdiPartner[]     // Phase 23
  ediTransactions EdiTransaction[] // Phase 23
  tickets          Ticket[]           // Phase 24
  notifications    Notification[]     // Phase 25
  customerAccounts CustomerAccount[]  // Customer Portal
}

// ── User ──────────────────────────────────────────────────────────────────────
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        String    @default("operator")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
}

// ── Order ─────────────────────────────────────────────────────────────────────
model Order {
  id          String    @id @default(cuid())
  customer    String
  sku         String
  items       Int       @default(1)
  value       Float     @default(0)
  stage       String    @default("Placed")
  priority    String    @default("MED")
  source      String    @default("manual")
  notes       String    @default("")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
}

// ── Invoice ───────────────────────────────────────────────────────────────────
model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String
  customer      String
  items         Json
  subtotal      Float     @default(0)
  tax           Float     @default(0)
  total         Float     @default(0)
  amountPaid    Float     @default(0)
  paymentTerms  String    @default("Net 30")
  issueDate     String
  dueDate       String
  status        String    @default("unpaid")
  notes         String    @default("")
  currency      String    @default("USD")  // Phase 15
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  createdAt     DateTime  @default(now())
}

// ── Customer ──────────────────────────────────────────────────────────────────
model Customer {
  id          String    @id @default(cuid())
  name        String
  contactName String
  email       String
  phone       String    @default("")
  country     String    @default("")
  industry    String    @default("")
  creditLimit Float     @default(0)
  balanceDue  Float     @default(0)
  totalSpend  Float     @default(0)
  status      String    @default("active")
  portalCode  String    @default("")
  notes           String    @default("")
  orders          Json      @default("[]")
  whatsappPaused  Boolean   @default(false)  // Phase 11
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  createdAt       DateTime  @default(now())

  @@unique([portalCode, workspaceId])
}

// ── Quote ─────────────────────────────────────────────────────────────────────
model Quote {
  id           String    @id @default(cuid())
  quoteNumber  String
  customer     String
  items        Json
  subtotal     Float     @default(0)
  discountAmt  Float     @default(0)
  tax          Float     @default(0)
  total        Float     @default(0)
  validUntil   String
  paymentTerms String    @default("Net 30")
  notes        String    @default("")
  status       String    @default("draft")
  prompt       String    @default("")
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
}

// ── Inventory Item ────────────────────────────────────────────────────────────
model InventoryItem {
  id           String    @id @default(cuid())
  sku          String
  name         String
  category     String
  stockLevel   Int       @default(0)
  reorderPoint Int       @default(0)
  reorderQty   Int       @default(0)
  unitCost     Float     @default(0)
  warehouse    String    @default("")
  zone         String    @default("A")
  binLocation  String    @default("")
  lastSynced   String
  supplier     String    @default("")
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
}

// ── Supplier ──────────────────────────────────────────────────────────────────
model Supplier {
  id           String    @id @default(cuid())
  name         String
  contactName  String
  email        String
  phone        String    @default("")
  country      String    @default("")
  category     String    @default("other")
  status       String    @default("active")
  paymentTerms String    @default("Net 30")
  leadTimeDays Int       @default(14)
  rating       Int       @default(3)
  notes        String    @default("")
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
}

// ── Purchase Order ────────────────────────────────────────────────────────────
model PurchaseOrder {
  id             String    @id @default(cuid())
  poNumber       String
  supplierId     String
  supplierName   String
  items          Json
  subtotal       Float     @default(0)
  tax            Float     @default(0)
  total          Float     @default(0)
  status         String    @default("draft")
  paymentTerms   String    @default("Net 30")
  expectedDate   String
  notes          String    @default("")
  rejectionNote  String    @default("")
  approvalStatus String    @default("not_required")
  approvedBy     String    @default("")
  approvedAt     String    @default("")
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime  @default(now())
}

// ── Shipment ──────────────────────────────────────────────────────────────────
model Shipment {
  id             String    @id @default(cuid())
  shipmentNumber String
  orderId        String?
  customer       String
  carrier        String    @default("Other")
  trackingNumber String    @default("")
  status         String    @default("pending")
  origin         String    @default("")
  destination    String    @default("")
  weight         String    @default("")
  dimensions     String    @default("")
  estimatedDate  String    @default("")
  deliveredDate  String    @default("")
  events         Json      @default("[]")
  notes          String    @default("")
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime  @default(now())
}

// ── Pricing Rule ─────────────────────────────────────────────────────────────
// Phase 12 — Pricing Rules Engine
// Two rule types:
//   "volume"   — discount kicks in when line-item qty >= minQty
//   "customer" — discount always applies for a named customer
model PricingRule {
  id           String    @id @default(cuid())
  name         String                          // human label, e.g. "Bulk 200+ deal"
  type         String                          // "volume" | "customer"
  minQty       Int       @default(0)           // volume rules: minimum qty to trigger
  customerName String    @default("")          // customer rules: exact customer name
  discountPct  Float     @default(0)           // discount percentage e.g. 10 = 10%
  active       Boolean   @default(true)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
}

// ── Contract & SLA Tracker ───────────────────────────────────────────────────
// Phase 12 (roadmap) — track contracts with customers.
// Status is auto-derived: draft → active → expiring (≤30 days) → expired
model Contract {
  id             String    @id @default(cuid())
  contractNumber String
  title          String
  customer       String
  minOrderQty    Int       @default(0)    // agreed minimum order quantity per period
  agreedPricing  String    @default("")   // free-text description of pricing terms
  deliverySLA    Int       @default(7)    // max delivery days agreed in contract
  value          Float     @default(0)   // total contract value
  startDate      String
  expiryDate     String
  status         String    @default("active") // draft | active | expiring | expired
  notes          String    @default("")
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  createdAt      DateTime  @default(now())
}

// ── Return / RMA ──────────────────────────────────────────────────────────────
// Phase 18 — Returns & RMA
// Status flow: requested → approved → received → refunded | rejected
model Return {
  id           String    @id @default(cuid())
  rmaNumber    String
  orderId      String?
  customer     String
  sku          String
  qty          Int       @default(1)
  reason       String    @default("other")
  description  String    @default("")
  status        String    @default("requested")
  refundAmount  Float     @default(0)
  refundMethod  String    @default("original")
  notes         String    @default("")
  customerEmail String    @default("")           // set when customer submits via portal
  workspaceId   String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ── EDI Trading Partner ───────────────────────────────────────────────────────
// Phase 23 — EDI Support (X12 + EDIFACT)
// One record per trading partner (customer or supplier that uses EDI).
model EdiPartner {
  id             String    @id @default(cuid())
  name           String                        // human label, e.g. "Acme Corp EDI"
  standard       String    @default("X12")     // "X12" | "EDIFACT"
  // X12 ISA identifiers
  isaQualifier   String    @default("01")       // ISA06 sender qual
  isaId          String    @default("")         // ISA06 sender ID (15 chars)
  partnerQual    String    @default("01")       // ISA08 receiver qual
  partnerId      String    @default("")         // ISA08 receiver ID
  // EDIFACT UNB identifiers
  unbSenderId    String    @default("")
  unbReceiverId  String    @default("")
  // which transaction sets this partner uses
  txSets         String    @default("850,855,856,810") // comma-separated
  active         Boolean   @default(true)
  notes          String    @default("")
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  transactions   EdiTransaction[]
  createdAt      DateTime  @default(now())
}

// ── EDI Transaction Log ───────────────────────────────────────────────────────
// One row per EDI message sent or received.
model EdiTransaction {
  id              String     @id @default(cuid())
  direction       String                           // "inbound" | "outbound"
  standard        String     @default("X12")       // "X12" | "EDIFACT"
  txSet           String                           // e.g. "850", "ORDERS"
  controlNumber   String     @default("")
  partnerId       String
  partner         EdiPartner @relation(fields: [partnerId], references: [id])
  status          String     @default("received")  // received | processed | error | sent | acked
  rawPayload      String     @db.Text             // full EDI text stored for audit
  parsedJson      Json?                            // parsed structured data
  errorMsg        String     @default("")
  workspaceId     String
  workspace       Workspace  @relation(fields: [workspaceId], references: [id])
  createdAt       DateTime   @default(now())
}

// ── Ticket ────────────────────────────────────────────────────────────────────
model Ticket {
  id           String          @id @default(cuid())
  ticketNumber String
  title        String
  description  String          @default("")
  type         String          @default("issue")
  priority     String          @default("medium")
  status       String          @default("open")
  assignedTo   String          @default("")
  assignedName String          @default("")
  raisedBy     String          @default("")
  raisedName   String          @default("")
  linkedType   String          @default("")
  linkedId     String          @default("")
  linkedLabel  String          @default("")
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id])
  comments     TicketComment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String   @default("")
  authorName String   @default("")
  body       String
  createdAt  DateTime @default(now())
}

// ── Notification ──────────────────────────────────────────────────────────────
// Phase 25 — Persistent Notifications
// Written by server-side routes (tickets, orders, inventory automations).
// Read state is tracked per-record in the DB (not in localStorage).
model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  type        String    @default("info")    // invoice | inventory | order | contract | ticket
  severity    String    @default("info")    // info | warn | error
  title       String
  body        String    @default("")
  tab         String    @default("")        // the app tab to navigate to
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

// ── Customer Portal ───────────────────────────────────────────────────────────
// Customer-facing portal accounts (separate from internal User accounts).
// Customers sign up at /portal/[workspaceId] with email + password.
model CustomerAccount {
  id          String            @id @default(cuid())
  email       String
  name        String            @default("")
  password    String            @default("")  // bcrypt hash
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  sessions    CustomerSession[]
  createdAt   DateTime          @default(now())

  @@unique([email, workspaceId])
}

model CustomerSession {
  id        String          @id @default(cuid())
  token     String          @unique @default(cuid())
  accountId String
  account   CustomerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime        @default(now())
}
