# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL = pooled connection (for app runtime, has "-pooler" in hostname)
# DIRECT_DATABASE_URL = direct connection (for migrations, no "-pooler")

DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ── Resend (email sending) ─────────────────────────────────────────────────────
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# ── Anthropic (AI quote generation) ───────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ── Stripe (payment processing) ────────────────────────────────────────────────
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# ── Twilio (WhatsApp messaging) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
