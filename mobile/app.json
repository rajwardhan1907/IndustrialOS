{
  "expo": {
    "name":        "IndustrialOS",
    "slug":        "industrialos",
    "version":     "1.0.0",
    "orientation": "portrait",
    "icon":        "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A2A4A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.industrialos.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for barcode scanning in the warehouse",
        "NSLocationWhenInUseUsageDescription": "Used for warehouse zone detection"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A2A4A"
      },
      "package": "com.industrialos.app",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera",      { "cameraPermission": "Allow IndustrialOS to access your camera for barcode scanning." }],
      ["expo-notifications",{ "icon": "./assets/icon.png", "color": "#2C4A8F" }]
    ],
    "scheme": "industrialos",
    "web": { "bundler": "metro", "output": "static" },
    "extra": {
      "eas": { "projectId": "industrialos" }
    }
  }
}
