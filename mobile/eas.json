{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
  "preview": {
  "distribution": "internal",
  "env": {
    "EXPO_PUBLIC_API_URL": "https://industrial-os-ort3.vercel.app"
  }
}
